# thank you claudia for writing me this majestig .gitignore

# ── secrets ───────────────────────────
.env
.env.*
*.env

# ── assets ──────────────────────
emojis/
pfp/


# ── python cache ──────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── virtual environments ──────────────
venv/
.env/
.venv/

# ── IDE / editor ──────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS junk ───────────────────────────
.DS_Store
Thumbs.db

# ── logs ──────────────────────────────
*.log

# ── database (linked tags) ───────
linked_tags.db
*.sqlite
*.db

# ── matplotlib / temp files ───────────
*.png
*.jpg

# ── build / dist ──────────────────────
build/
dist/
*.egg-info/